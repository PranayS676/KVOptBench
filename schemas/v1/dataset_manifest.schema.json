{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Reproducibility manifest for a generated dataset workload.",
  "properties": {
    "adapter": {
      "title": "Adapter",
      "type": "string"
    },
    "adapter_name": {
      "title": "Adapter Name",
      "type": "string"
    },
    "adapter_version": {
      "title": "Adapter Version",
      "type": "string"
    },
    "avg_input_tokens": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Avg Input Tokens"
    },
    "cache_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Dir"
    },
    "cache_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Path"
    },
    "context_buckets": {
      "items": {
        "type": "integer"
      },
      "title": "Context Buckets",
      "type": "array"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "dataset": {
      "title": "Dataset",
      "type": "string"
    },
    "dataset_name": {
      "title": "Dataset Name",
      "type": "string"
    },
    "dataset_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset Revision"
    },
    "dataset_source_url": {
      "title": "Dataset Source Url",
      "type": "string"
    },
    "download_method": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Download Method"
    },
    "downloaded_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Downloaded At"
    },
    "excluded_count": {
      "default": 0,
      "title": "Excluded Count",
      "type": "integer"
    },
    "exclusion_reasons": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Exclusion Reasons",
      "type": "object"
    },
    "generation_command": {
      "title": "Generation Command",
      "type": "string"
    },
    "generation_duration_sec": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generation Duration Sec"
    },
    "generation_finished_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generation Finished At"
    },
    "generation_started_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generation Started At"
    },
    "git_commit": {
      "title": "Git Commit",
      "type": "string"
    },
    "input_token_histogram": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Input Token Histogram",
      "type": "object"
    },
    "items_per_prefix_group": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Items Per Prefix Group",
      "type": "object"
    },
    "known_limitations": {
      "items": {
        "type": "string"
      },
      "title": "Known Limitations",
      "type": "array"
    },
    "kvoptbench_version": {
      "default": "0.1.0",
      "title": "Kvoptbench Version",
      "type": "string"
    },
    "license": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "License"
    },
    "license_review_status": {
      "title": "License Review Status",
      "type": "string"
    },
    "manifest_version": {
      "default": "1",
      "title": "Manifest Version",
      "type": "string"
    },
    "max_input_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Input Tokens"
    },
    "max_items_emitted": {
      "default": 0,
      "title": "Max Items Emitted",
      "type": "integer"
    },
    "max_items_requested": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Items Requested"
    },
    "min_input_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Min Input Tokens"
    },
    "mode": {
      "title": "Mode",
      "type": "string"
    },
    "normalization_rules": {
      "items": {
        "type": "string"
      },
      "title": "Normalization Rules",
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    },
    "prefix_group_count": {
      "default": 0,
      "title": "Prefix Group Count",
      "type": "integer"
    },
    "prompt_template": {
      "title": "Prompt Template",
      "type": "string"
    },
    "prompt_template_hash": {
      "title": "Prompt Template Hash",
      "type": "string"
    },
    "python_version": {
      "title": "Python Version",
      "type": "string"
    },
    "redistribution_policy": {
      "title": "Redistribution Policy",
      "type": "string"
    },
    "rights_note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rights Note"
    },
    "row_count": {
      "title": "Row Count",
      "type": "integer"
    },
    "sampling_method": {
      "default": "deterministic",
      "title": "Sampling Method",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "seed": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Seed"
    },
    "source_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Revision"
    },
    "source_sha256": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Sha256"
    },
    "source_url": {
      "title": "Source Url",
      "type": "string"
    },
    "split": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Split"
    },
    "target_input_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Input Tokens"
    },
    "target_output_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Output Tokens"
    },
    "token_count_method": {
      "title": "Token Count Method",
      "type": "string"
    },
    "tokenizer_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tokenizer Id"
    },
    "tokenizer_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tokenizer Revision"
    },
    "truncation_count": {
      "default": 0,
      "title": "Truncation Count",
      "type": "integer"
    },
    "truncation_policy": {
      "default": "none",
      "title": "Truncation Policy",
      "type": "string"
    },
    "workload_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workload Hash"
    },
    "workload_sha256": {
      "title": "Workload Sha256",
      "type": "string"
    }
  },
  "required": [
    "adapter_name",
    "adapter_version",
    "dataset_name",
    "dataset",
    "dataset_source_url",
    "source_url",
    "license_review_status",
    "redistribution_policy",
    "adapter",
    "mode",
    "generation_command",
    "token_count_method",
    "row_count",
    "workload_sha256",
    "prompt_template",
    "prompt_template_hash"
  ],
  "title": "DatasetManifest",
  "type": "object",
  "x-kvoptbench-contract": "dataset_manifest",
  "x-kvoptbench-schema-version": "1"
}
