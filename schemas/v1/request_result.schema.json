{
  "$defs": {
    "MetricProvenance": {
      "description": "Explain where a metric came from and why it may be unavailable.",
      "properties": {
        "available": {
          "default": true,
          "title": "Available",
          "type": "boolean"
        },
        "measurement_method": {
          "title": "Measurement Method",
          "type": "string"
        },
        "missing_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Missing Reason"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "provider_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Field"
        },
        "source_type": {
          "enum": [
            "client_observed",
            "provider_reported",
            "engine_reported",
            "gpu_reported",
            "imported",
            "derived",
            "estimated"
          ],
          "title": "Source Type",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "source_type",
        "measurement_method"
      ],
      "title": "MetricProvenance",
      "type": "object"
    },
