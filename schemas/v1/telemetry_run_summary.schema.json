{
  "$defs": {
    "MissingMetric": {
      "description": "One metric that was unavailable in a supplied telemetry artifact.",
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        }
      },
      "required": [
        "metric",
        "reason"
      ],
      "title": "MissingMetric",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Run-level telemetry artifact summary.",
  "properties": {
    "enabled": {
      "title": "Enabled",
      "type": "boolean"
    },
    "finished_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finished At"
    },
    "metrics": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Metrics",
      "type": "object"
    },
    "missing_metrics": {
      "items": {
        "$ref": "#/$defs/MissingMetric"
      },
      "title": "Missing Metrics",
      "type": "array"
    },
    "output_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Dir"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "snapshot_count": {
      "default": 0,
      "title": "Snapshot Count",
      "type": "integer"
    },
    "snapshots_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Snapshots Path"
    },
    "sources": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Sources",
      "type": "array"
    },
    "started_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "summary_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary Path"
    }
  },
  "required": [
    "run_id",
    "enabled"
  ],
  "title": "TelemetryRunSummary",
  "type": "object",
  "x-kvoptbench-contract": "telemetry_run_summary",
  "x-kvoptbench-schema-version": "1"
}
